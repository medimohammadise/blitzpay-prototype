# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Auth Bypass (dev only) ---
# Set to "true" to skip Keycloak and auto-login as a dev user (no Keycloak needed).
# Must be "false" or absent in production.
VITE_AUTH_BYPASS=false

# --- Keycloak Authentication ---
# VITE_ prefix exposes these to the browser bundle.
# Point to your Keycloak server (local: http://localhost:8080, or hosted URL).
VITE_KEYCLOAK_URL="http://localhost:8080"

# The Keycloak realm name for this app.
VITE_KEYCLOAK_REALM="blitzpay"

# The Keycloak public client ID (created in the admin console).
VITE_KEYCLOAK_CLIENT_ID="blitzpay-spa"

# Service account secret for the server-side registration proxy.
# CRITICAL: No VITE_ prefix — must never be exposed to the browser bundle.
# ID of the confidential server-side client (see Keycloak setup steps).
KEYCLOAK_SERVER_CLIENT_ID="blitz-pay-server"
KEYCLOAK_ADMIN_SECRET="MY_KEYCLOAK_ADMIN_SECRET"

# --- Mobile Observability -> Grafana OTLP ---
# Server-side OTLP logs endpoint. If using Grafana Cloud OTLP gateway, set to:
# https://otlp-gateway-<region>.grafana.net/otlp
# The server appends /v1/logs automatically.
OBS_OTLP_LOGS_ENDPOINT=""

# Optional extra resource attribute attached by the server.
OBS_OTLP_SERVICE_NAMESPACE="blitzpay"

# HTTP header used to authenticate against OTLP.
# Grafana Cloud uses:
# OBS_OTLP_AUTH_HEADER="Authorization"
# OBS_OTLP_AUTH_VALUE="Basic <base64(instance_id:api_token)>"
OBS_OTLP_AUTH_HEADER="Authorization"
OBS_OTLP_AUTH_VALUE=""
